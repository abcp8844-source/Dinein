{
  "expo": {
    "name": "Dining Table",
    "slug": "dining-table",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "dining-table",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.abcp.diningtable"
    },
    "android": {
      "package": "com.abcp.diningtable",
      "versionCode": 4,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "INTERNET",
        "CAMERA"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "df595d95-668f-4346-a79a-e141ed024403"
      }
    },
    "plugins": [
      "expo-router"
    ]
  }
}
